generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WorkflowDefinition {
  id          String   @id @default(cuid())
  name        String
  module      String
  isActive    Boolean  @default(true)
  instances   WorkflowInstance[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkflowInstance {
  id           String   @id @default(cuid())
  definitionId String
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id])
  referenceId  String?
  status       String   @default("Pending") // Pending, Approved, Rejected, Completed
  currentNode  String
  tasks        WorkflowTask[]
  auditLogs    WorkflowAuditLog[]
  startedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkflowTask {
  id           String   @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id])
  assignedRole String?
  assignedUser String?
  status       String   @default("Pending") // Pending, Approved, Rejected
  auditLogs    WorkflowAuditLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkflowAuditLog {
  id           String   @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id])
  taskId       String?
  task         WorkflowTask? @relation(fields: [taskId], references: [id])
  action       String
  actor        String
  comments     String?
}

// ==========================================
// ERP MODULES EXPANSION
// ==========================================

model AdmissionApplication {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  dob       String
  grade     String
  guardian  String
  phone     String
  status    String   @default("Pending") // Pending, Approved, Rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeInvoice {
  id          String   @id @default(cuid())
  studentId   String?
  studentName String
  grade       String
  description String
  amount      Float
  status      String   @default("Pending") // Pending, Paid, Overdue
  date        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LedgerTransaction {
  id        String   @id @default(cuid())
  type      String   // Income, Expense
  category  String
  amount    Float
  account   String?
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  role      String
  salary    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payslip {
  id           String   @id @default(cuid())
  employeeId   String?
  employeeName String
  role         String
  amount       Float
  date         String
  status       String   @default("Pending") // Pending, Processed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AssetItem {
  id        String   @id @default(cuid())
  name      String
  category  String
  quantity  Int
  location  String
  status    String   @default("In Stock") // In Stock, Low Stock
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransportRoute {
  id        String   @id @default(cuid())
  name      String
  vehicle   String
  driver    String
  stops     Int
  status    String   @default("Active") // Active, Maintenance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LibraryBook {
  id        String   @id @default(cuid())
  title     String
  author    String
  category  String
  status    String   @default("Available") // Available, Issued
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id        String   @id @default(cuid())
  subject   String
  user      String
  priority  String   @default("Medium") // High, Medium, Low
  status    String   @default("Open") // Open, In Progress, Resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
